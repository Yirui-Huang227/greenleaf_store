<div class="row justify-content-center">
  <div class="col-lg-8">

    <h2 class="mb-4 text-center">About Us</h2>

    <% if @about_page.present? %>
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <% if @about_page.title.present? %>
            <h3 class="mb-3"><%= @about_page.title %></h3>
          <% end %>

          <div class="text-muted">
            <%= simple_format(@about_page.about) %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5">
          <h5 class="mb-3">About page content is not available yet</h5>
          <p class="text-muted">Please check back later.</p>
        </div>
      </div>
    <% end %>

  </div>
</div>