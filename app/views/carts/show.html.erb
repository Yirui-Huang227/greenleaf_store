<h1>My Cart</h1>

<% if @cart_items.any? %>
  <%= render partial: "cart_item", collection: @cart_items, as: :item %>

  <p><strong>Total: <%= number_to_currency(@cart_total) %></strong></p>
<% else %>
  <p>Your cart is empty.</p>
<% end %>
<%= form_with url: checkout_path, method: :post, local: true do %>
  <%= submit_tag "Place Order" %>
<% end %>