<h1>My Orders</h1>

<% if @orders.any? %>
  <% @orders.each do |order| %>
    <p>
      <%= link_to "Order ##{order.id}", order_path(order) %>
      - <%= number_to_currency(order.total) %>
      - <%= order.created_at.strftime("%B %d, %Y") %>
    </p>
  <% end %>
<% else %>
  <p>You have no orders yet.</p>
<% end %>
